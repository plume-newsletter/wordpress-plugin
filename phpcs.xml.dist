<?xml version="1.0"?>
<ruleset name="Plume Newsletter">
  <description>WordPress-Extra checks for the Plume signup plugin.</description>
  <file>plume-newsletter.php</file>
  <file>includes</file>
  <file>uninstall.php</file>
  <arg name="extensions" value="php"/>
  <arg value="ps"/>
  <rule ref="WordPress-Extra"/>
  <config name="testVersion" value="7.4-"/>
</ruleset>
