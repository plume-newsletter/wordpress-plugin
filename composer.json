{
  "name": "plume-newsletter/wordpress-plugin",
  "description": "Plume Newsletter signup form for WordPress.",
  "license": "GPL-2.0-or-later",
  "type": "wordpress-plugin",
  "require": { "php": ">=7.4" },
  "require-dev": { "phpunit/phpunit": "^9.6",
    "squizlabs/php_codesniffer": "^3.9",
    "wp-coding-standards/wpcs": "^3.1",
    "phpcsstandards/phpcsextra": "^1" },
  "scripts": { "test": "phpunit", "lint": "phpcs", "fix": "phpcbf" },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
