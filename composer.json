{
  "name": "plume-newsletter/wordpress-plugin",
  "description": "Plume Newsletter signup form for WordPress.",
  "license": "GPL-2.0-or-later",
  "type": "wordpress-plugin",
  "require": { "php": ">=7.4" },
  "require-dev": { "phpunit/phpunit": "^9.6",
    "squizlabs/php_codesniffer": "^3.9",
    "wp-coding-standards/wpcs": "^3.1",
    "phpcsstandards/phpcsextra": "^1",
    "wp-cli/i18n-command": "^2.7" },
  "scripts": {
    "test": "phpunit",
    "lint": "phpcs",
    "fix": "phpcbf",
    "i18n": "wp i18n make-pot . languages/plume-newsletter.pot --exclude=vendor,tests,.github,node_modules --domain=plume-newsletter"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
